<controls:ModalDialog x:Class="TimePunch_WPF_StackedModern_Demo.Views.LogonDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TimePunch_WPF_StackedModern_Demo.Views"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:controls="clr-namespace:TimePunch.StackedUI.Controls;assembly=TpStackedUI"
             DataContext="{Binding Source={StaticResource ViewModelLocator}, Path=LogonViewModel}"
             mc:Ignorable="d" 
             Title="Logon"
             FullSizeDesired="False"
             PrimaryButtonText="Logon"
             PrimaryButtonCommand="{Binding PrimaryButtonCommand}"
             IsPrimaryButtonEnabled="True"
             IsSecondaryButtonEnabled="False"
             CloseButtonText="Cancel"
             CloseButtonCommand="{Binding CancelDialogCommand}"
             DefaultButton="Primary"
             controls:AttachedProperties.DialogResult="{Binding DialogResult}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ui:SimpleStackPanel >
            <TextBox
                ui:ControlHelper.Header="Do something really cool"
                AcceptsReturn="True" />

        </ui:SimpleStackPanel>            
    </Grid>
</controls:ModalDialog>
