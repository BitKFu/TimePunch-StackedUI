<controls:ModalDialog x:Class="TimePunch_WinUI_StackedUI_Demo.Views.LogonDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="using:TimePunch.StackedUI.Controls"
             mc:Ignorable="d" 
             Title="Logon"
             PrimaryButtonText="Logon"
             PrimaryButtonCommand="{Binding PrimaryButtonCommand}"
             IsPrimaryButtonEnabled="True"
             IsSecondaryButtonEnabled="False"
             CloseButtonText="Cancel"
             CloseButtonCommand="{Binding CancelDialogCommand}"
             DefaultButton="Primary"
             DataContext="{Binding Source={StaticResource ViewModelLocator}, Path=LogonViewModel}"
             controls:AttachedProperties.DialogResult="{Binding DialogResult}"
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Vertical">
        <TextBox AcceptsReturn="True" Header="Do something really cool" />
    </StackPanel>
</controls:ModalDialog>
