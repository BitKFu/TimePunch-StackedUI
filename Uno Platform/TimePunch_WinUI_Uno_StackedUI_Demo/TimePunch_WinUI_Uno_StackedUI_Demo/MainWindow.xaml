<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TimePunch_WinUI_StackedUI_Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:stackedUi="using:TimePunch.StackedUI"
    xmlns:controls="using:TimePunch.StackedUI.Controls"
    mc:Ignorable="d">
    <controls:DpiDecorator x:Name="DpiDecorator" x:FieldModifier="public" Scale="1">
        <Grid x:Name="ContentGrid"
              DataContext="{Binding Source={StaticResource ViewModelLocator}, Path=MainWindowViewModel}"
              Loaded="FrameworkElement_OnLoaded">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="16,12">
                <TextBlock Text="TimePunch Stacked UI Demo" FontSize="20" />
            </Border>

            <NavigationView Grid.Row="1"
                            IsBackButtonVisible="Collapsed"
                            IsBackEnabled="False"
                            IsPaneOpen="True"
                            IsSettingsVisible="False"
                            SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                            FooterMenuItemsSource="{Binding Path=FooterPages, Mode=OneWay}"
                            MenuItemsSource="{Binding Path=DemoPages, Mode=OneWay}">
                <NavigationView.MenuItemTemplate>
                    <DataTemplate>
                        <NavigationViewItem Icon="{Binding Path=Icon, Converter={StaticResource IconConverter}}"
                                            Content="{Binding Path=Title}"
                                            AutomationProperties.Name="{Binding Path=Title}" />
                    </DataTemplate>
                </NavigationView.MenuItemTemplate>

                <stackedUi:StackedFrame x:Name="StackedFrame"
                                        FadeInDuration="100"
                                        FadeOutDuration="100"
                                        StackedMode="Resizeable" />
            </NavigationView>
        </Grid>
    </controls:DpiDecorator>
</UserControl>
